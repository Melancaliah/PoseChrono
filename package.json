{
  "name": "posechrono-tooling",
  "version": "0.0.1",
  "private": true,
  "description": "Tooling scripts for PoseChrono release and verification",
  "scripts": {
    "version:bump": "node scripts/bump-version.js",
    "desktop:sync-web": "node scripts/sync-desktop-web.js",
    "desktop:install": "npm --prefix apps/desktop install",
    "desktop:start": "npm --prefix apps/desktop run start",
    "desktop:build:win:unsigned": "npm --prefix apps/desktop run build:win:unsigned",
    "desktop:build:win": "npm --prefix apps/desktop run build:win",
    "release:clean": "node scripts/clean-releases.js",
    "release:clean:dry": "node scripts/clean-releases.js --dry-run",
    "release:windows": "node scripts/release-windows.js",
    "release:all": "node scripts/release-all.js",
    "release:eagle": "node scripts/release-eagle.js",
    "release:desktop": "node scripts/release-desktop.js",
    "verify:eagle-dist": "node scripts/verify-eagle-dist.js",
    "verify:desktop-dist": "node scripts/verify-desktop-dist.js",
    "verify:locales": "node scripts/verify-locales.js",
    "verify:smoke": "node scripts/verify-smoke.js",
    "verify:builds": "node scripts/verify-builds.js"
  }
}
